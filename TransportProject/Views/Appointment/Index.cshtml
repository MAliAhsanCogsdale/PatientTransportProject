@model TransportProject.ViewModels.AppointmentListVM

@{
    ViewData["Title"] = "Appointments";
}

<div class="container mt-4">
    <div class="row mb-3">
        <div class="col-md-12">
            <h2><i class="bi bi-calendar-check"></i> Appointments</h2>
        </div>
    </div>

    <!-- Search and Filter -->
    <div class="card mb-3">
        <div class="card-body">
            <form method="get" asp-action="Index">
                <div class="row g-3">
                    <div class="col-md-3">
                        <label for="searchDriver" class="form-label">Driver Name</label>
                        <input type="text" class="form-control" id="searchDriver" name="searchDriver" value="@Context.Request.Query["searchDriver"]" placeholder="Search driver...">
                    </div>
                    <div class="col-md-3">
                        <label for="searchPatient" class="form-label">Patient Name</label>
                        <input type="text" class="form-control" id="searchPatient" name="searchPatient" value="@Context.Request.Query["searchPatient"]" placeholder="Search patient...">
                    </div>
                    <div class="col-md-3">
                        <label for="date" class="form-label">Date</label>
                        <input type="date" class="form-control" id="date" name="date" value="@Context.Request.Query["date"]">
                    </div>
                    <div class="col-md-3 d-flex align-items-end">
                        <button type="submit" class="btn btn-primary me-2">
                            <i class="bi bi-search"></i> Search
                        </button>
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-x-circle"></i> Clear
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Action Buttons -->
    <div class="mb-3">
        <a asp-action="ImportFile" class="btn btn-success">
            <i class="bi bi-file-earmark-arrow-up"></i> Import from PDF
        </a>
    </div>

    <!-- Results Table -->
    <div class="card">
        <div class="card-body">
            @if (Model.Items.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>Driver</th>
                                <th>Patient</th>
                                <th>Pickup Time</th>
                                <th>Pickup Address</th>
                                <th>Drop-Off Time</th>
                                <th>Drop-Off Location</th>
                                <th>LOS</th>
                                <th>Miles</th>
                                <th>CPay</th>
                                <th>Seq</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td>@item.DriverName</td>
                                    <td>@item.PatientName</td>
                                    <td>@item.PickupTime.ToString("MM/dd/yyyy hh:mm tt")</td>
                                    <td><small>@item.PickupAddress</small></td>
                                    <td>@(item.DropOffTime?.ToString("hh:mm tt") ?? "-")</td>
                                    <td><small>@item.DropOffAddress</small></td>
                                    <td>@item.LOS</td>
                                    <td>@item.Miles?.ToString("F1")</td>
                                    <td>@item.CPay?.ToString("C")</td>
                                    <td>
                                        <span class="badge bg-info">@item.SequenceOrder</span>
                                    </td>
                                    <td>
                                        <span class="badge bg-@(item.Status == "Completed" ? "success" : "warning")">
                                            @item.Status
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Pagination -->
                @if (Model.TotalPages > 1)
                {
                    <nav aria-label="Page navigation">
                        <ul class="pagination justify-content-center">
                            @for (int i = 1; i <= Model.TotalPages; i++)
                            {
                                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                    <a class="page-link" asp-action="Index" asp-route-page="@i"
                                       asp-route-searchDriver="@Context.Request.Query["searchDriver"]"
                                       asp-route-searchPatient="@Context.Request.Query["searchPatient"]"
                                       asp-route-date="@Context.Request.Query["date"]">
                                        @i
                                    </a>
                                </li>
                            }
                        </ul>
                    </nav>
                }

                <p class="text-muted text-center">
                    Showing @Model.Items.Count of @Model.TotalRecords records
                </p>
            }
            else
            {
                <div class="alert alert-warning" role="alert">
                    <i class="bi bi-exclamation-triangle"></i> No appointments found. Import a PDF file to get started.
                </div>
            }
        </div>
    </div>
</div>