@{
    var title = ViewData["Title"] ?? "Transport System";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@title</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        body {
            overflow-x: hidden;
        }

        .sidebar {
            height: 100vh;
            background: #2c3e50;
            color: white;
        }

            .sidebar a {
                color: white;
                text-decoration: none;
                display: block;
                padding: 10px;
            }

                .sidebar a:hover {
                    background: #34495e;
                }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">

            <!-- Sidebar -->
            <div class="col-md-2 sidebar">
                <h4 class="text-center mt-3">Patient Transport System</h4>
                <hr />
                <a asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                <a asp-controller="RouteAppointment" asp-action="Index">Route Appointment</a>
                <a asp-controller="Driver" asp-action="Index">Drivers</a>
                <a asp-controller="Patient" asp-action="Index">Patients</a>
                <a asp-controller="Hospital" asp-action="Index">Hospitals</a>
                <a asp-controller="Role" asp-action="Index">Roles</a>
                <a asp-controller="Vehicle" asp-action="Index">Vehicles</a>
                <a asp-controller="Appointment" asp-action="Index">Appointments</a>
                <a asp-controller="Route" asp-action="Index">Routes</a>
                <a asp-controller="Auth" asp-action="Logout" class="text-danger">Logout</a>
            </div>

            <!-- Main Content -->
            <div class="col-md-10 p-4">
                <nav class="navbar navbar-light bg-light mb-4">
                    <span class="navbar-brand">Welcome @User.Identity.Name</span>
                </nav>

                @RenderBody()
            </div>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Allow pages to define their own scripts -->
    @RenderSection("Scripts", required: false)
</body>
</html>