@model TransportProject.Models.Driver

@{
    ViewData["Title"] = "Delete Driver";
}

<h2>Delete Driver</h2>

<div class="alert alert-danger">
Are you sure you want to delete this driver?
</div>

<div class="card p-3">
n<p><strong>Name:</strong> @Model.FirstName @Model.LastName</p>
n<p><strong>Phone:</strong> @Model.Phone</p>
n<p><strong>Vehicle Id:</strong> @Model.VehicleId</p>
n<p><strong>Status:</strong> @Model.Status</p>

</div>

<form asp-action="Delete" method="post">

<input type="hidden" asp-for="Id"/>

<button type="submit" class="btn btn-danger">
Delete
</button>

<a asp-action="Index" class="btn btn-secondary ms-2">
Cancel
</a>

</form>
