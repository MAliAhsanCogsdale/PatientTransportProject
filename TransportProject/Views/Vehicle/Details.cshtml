@model TransportProject.Models.Vehicle

<h2>Vehicle Details</h2>

<div class="card">
    <div class="card-body">

        <p><strong>Name:</strong> @Model.VehicleName</p>
        <p><strong>Model:</strong> @Model.Model</p>
        <p><strong>Number:</strong> @Model.VehicleNumber</p>
        <p><strong>Capacity:</strong> @Model.Capacity</p>
        <p><strong>Description:</strong> @Model.Description</p>
        <p><strong>Active:</strong> @(Model.IsActive ? "Yes" : "No")</p>

    </div>
</div>

<br />

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
<a asp-action="Index" class="btn btn-secondary">Back</a>