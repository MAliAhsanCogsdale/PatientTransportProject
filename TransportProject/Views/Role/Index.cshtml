@model IEnumerable<TransportProject.Models.Role>

<h2>Roles</h2>

<a class="btn btn-primary mb-2" asp-action="Create">Add Role</a>

<form method="get" class="mb-3">
    <input type="text" name="search" placeholder="Search role..." class="form-control" />
</form>

<table class="table table-bordered">

    <thead class="table-dark">
        <tr>
            <th>Id</th>
            <th>Name</th>
            <th>Active</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Name</td>
                <td>@item.IsActive</td>

                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">View</a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Edit</a>
                    <a asp-action="Delete" asp-route-id="@item.Id"
                       class="btn btn-danger btn-sm"
                       onclick="return confirm('Are you sure?');">
                        Delete
                    </a>
                </td>
            </tr>
        }
    </tbody>

</table>