@using TransportProject.Helper_Classes
@using TransportProject.Models
@model PagedResult<Hospital>

<h2>Hospitals</h2>

<a class="btn btn-primary mb-2" asp-action="Create">Add Hospital</a>

<partial name="_Search" model="Model" />

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Area</th>
            <th>Phone</th>
            <th>Type</th>
            <th>Emergency</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model.Items)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Area</td>
                <td>@item.Phone</td>
                <td>@item.HospitalType</td>
                <td>@(item.EmergencyAvailable ? "Yes" : "No")</td>

                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">View</a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Edit</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<partial name="_Pagination" model="Model" />