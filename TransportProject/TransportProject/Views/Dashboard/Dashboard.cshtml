@{
    ViewData["Title"] = "Dashboard";
}

<h2>Dashboard</h2>

<div class="row mt-4">
    <div class="col-md-12">
        <canvas id="dashboardChart" height="100"></canvas>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Sample static data
        const data = {
            labels: ['Patients', 'Drivers', 'Appointments'],
            datasets: [{
                label: 'Total Count',
                data: [120, 45, 30], // Replace with real data from backend later
                backgroundColor: [
                    'rgba(54, 162, 235, 0.7)',
                    'rgba(75, 192, 192, 0.7)',
                    'rgba(255, 206, 86, 0.7)'
                ],
                borderColor: [
                    'rgba(54, 162, 235, 1)',
                    'rgba(75, 192, 192, 1)',
                    'rgba(255, 206, 86, 1)'
                ],
                borderWidth: 1
            }]
        };

        const config = {
            type: 'bar', // You can change to 'pie', 'doughnut', 'line', etc.
            data: data,
            options: {
                responsive: true,
                plugins: {
                    legend: {
                        display: false
                    },
                    title: {
                        display: true,
                        text: 'Dashboard Summary'
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            precision:0
                        }
                    }
                }
            }
        };

        new Chart(
            document.getElementById('dashboardChart'),
            config
        );
    </script>
}