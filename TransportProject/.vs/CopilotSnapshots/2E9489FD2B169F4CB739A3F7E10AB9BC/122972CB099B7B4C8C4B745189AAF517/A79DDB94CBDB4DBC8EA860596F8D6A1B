    [Authorize(Roles = "Admin,Dispatcher")]
    public class RouteAppointmentController : Controller
    {
        private readonly IRouteAppointmentRepository _repository;
        private readonly ApplicationDbContext _context;

        public RouteAppointmentController(IRouteAppointmentRepository repository, ApplicationDbContext context)
        {
            _repository = repository;
            _context = context;
        }

        public async Task<IActionResult> Index()
        {
            var items = await _repository.GetAllAsync();
            return View(items);
        }

        public async Task<IActionResult> Edit(int id)
        {
            var item = await _repository.GetByIdAsync(id);
            return View(item);
        }

        [HttpPost]
        public async Task<IActionResult> Edit(RouteAppointment model)
        {
            await _repository.UpdateAsync(model);
            return RedirectToAction(nameof(Index));
        }

        public async Task<IActionResult> Delete(int id)
        {
            await _repository.DeleteAsync(id);
            return RedirectToAction(nameof(Index));
        }

        // GET: show upload form
        public IActionResult ImportFile()
        {
            return View();
        }

        // POST: upload file (pdf or plain text). Shortest-path: if you need reliable PDF parsing, add the "UglyToad.PdfPig" NuGet package.
        // This implementation supports plain text files. If "UglyToad.PdfPig" is present in the app's bin it will be used via reflection to extract text from PDF.
        [HttpPost]
        [ValidateAntiForgeryToken]
        public async Task<IActionResult> ImportFile(IFormFile file)
        {
            if (file == null || file.Length == 0)
            {
                ModelState.AddModelError("file", "Please provide a file.");
                return View();
            }

            var tempPath = Path.Combine(Path.GetTempPath(), Guid.NewGuid() + Path.GetExtension(file.FileName));

            await using (var fs = System.IO.File.Create(tempPath))
                await file.CopyToAsync(fs);

            string rawText = "";

            try
            {
                var ext = Path.GetExtension(file.FileName).ToLower();

                if (ext == ".pdf")
                {
                    try
                    {
                        var asm = Assembly.Load("UglyToad.PdfPig");
                        var pdfDocType = asm.GetType("UglyToad.PdfPig.PdfDocument");
                        var openMethod = pdfDocType.GetMethod("Open", new[] { typeof(string) });

                        using var pdf = openMethod.Invoke(null, new object[] { tempPath });
                        var pages = pdf.GetType().GetMethod("GetPages").Invoke(pdf, null) as IEnumerable;

                        var sb = new StringBuilder();

                        foreach (var p in pages)
                        {
                            var text = p.GetType().GetProperty("Text").GetValue(p)?.ToString();
                            if (!string.IsNullOrWhiteSpace(text))
                                sb.AppendLine(text);
                        }

                        rawText = sb.ToString();
                    }
                    catch
                    {
                        ModelState.AddModelError("file", "Install UglyToad.PdfPig OR upload .txt file.");
                        return View();
                    }
                }
                else
                {
                    rawText = await System.IO.File.ReadAllTextAsync(tempPath);
                }

                rawText = rawText.Replace("\r\n", "\n").Replace("\r", "\n");

                // ✅ FIXED BLOCK SPLIT
                var blocks = Regex.Split(rawText, @"(?=\d{2}-\d{3,})");

                // 🔥 CACHE DATA (IMPORTANT)
                var hospitals = _context.Hospitals.ToList();
                var patients = _context.Patients.ToList();
                var drivers = _context.Drivers.Where(d => d.IsActive && d.IsAvailable).ToList();
                var routes = _context.Routes.ToList();

                int importedCount = 0;

                foreach (var raw in blocks)
                {
                    var block = raw.Trim();
                    if (string.IsNullOrWhiteSpace(block)) continue;

                    try
                    {
                        var lines = block.Split('\n').Select(x => x.Trim()).ToList();

                        string rideNumber = lines.FirstOrDefault() ?? "";

                        // ✅ NAME FIX
                        var nameMatch = Regex.Match(block, @"([A-Z]+,\s*[A-Z]+)");
                        string firstName = "", lastName = "";

                        if (nameMatch.Success)
                        {
                            var parts = nameMatch.Value.Split(',');
                            lastName = parts[0].Trim();
                            firstName = parts[1].Trim();
                        }

                        // ✅ TIME FIX
                        var times = Regex.Matches(block, @"\b\d{1,2}:\d{2}\b")
                                         .Cast<Match>()
                                         .Select(m => m.Value)
                                         .ToList();

                        DateTime pickup = DateTime.Today;
                        DateTime drop = DateTime.Today;

                        if (times.Count > 0) pickup += TimeSpan.Parse(times[0]);
                        if (times.Count > 1) drop += TimeSpan.Parse(times[1]);

                        // ✅ SIMPLE ADDRESS
                        var pickupAddress = lines.FirstOrDefault(l => l.Contains("PU")) ?? "";
                        var dropLine = lines.FirstOrDefault(l => l.StartsWith("DO")) ?? "";

                        var hospitalName = dropLine.Replace("DO", "").Trim();

                        // ✅ FIND OR CREATE HOSPITAL
                        var hospital = hospitals.FirstOrDefault(h => h.Name == hospitalName);
                        if (hospital == null)
                        {
                            hospital = new Hospital { Name = hospitalName };
                            _context.Hospitals.Add(hospital);
                            // persist now so we have an Id for FK usage
                            await _context.SaveChangesAsync();
                            hospitals.Add(hospital);
                        }

                        // ✅ FIND OR CREATE PATIENT
                        var patient = patients.FirstOrDefault(p => p.FirstName == firstName && p.LastName == lastName);

                        if (patient == null)
                        {
                            patient = new Patient
                            {
                                FirstName = firstName,
                                LastName = lastName,
                                Address = pickupAddress,
                                HospitalId = hospital.Id
                            };

                            _context.Patients.Add(patient);
                            // persist to get patient.Id
                            await _context.SaveChangesAsync();
                            patients.Add(patient);
                        }

                        // Extract LOS/CPay/PCA/AESC/CESC/Seats/Miles/Notes from block
                        string los = null;
                        string cpay = null;
                        string pca = null;
                        string aesc = null;
                        string cesc = null;
                        string seats = null;
                        string miles = null;
                        string notes = null;

                        try
                        {
                            var losMatch = Regex.Match(block, @"LOS:\s*(?<val>[^\r\n]*)", RegexOptions.IgnoreCase);
                            if (losMatch.Success) los = Regex.Replace(losMatch.Groups["val"].Value, @"\s+", " ").Trim();
                            var cpayMatch = Regex.Match(block, @"CPay:\s*\$?(?<val>[0-9,\.]+)", RegexOptions.IgnoreCase);
                            if (cpayMatch.Success) cpay = cpayMatch.Groups["val"].Value.Trim();
                            var pcaMatch = Regex.Match(block, @"PCA:\s*(?<val>\d+)", RegexOptions.IgnoreCase);
                            if (pcaMatch.Success) pca = pcaMatch.Groups["val"].Value.Trim();
                            var aescMatch = Regex.Match(block, @"AESC:\s*(?<val>\d+)", RegexOptions.IgnoreCase);
                            if (aescMatch.Success) aesc = aescMatch.Groups["val"].Value.Trim();
                            var cescMatch = Regex.Match(block, @"CESC:\s*(?<val>\d+)", RegexOptions.IgnoreCase);
                            if (cescMatch.Success) cesc = cescMatch.Groups["val"].Value.Trim();
                            var seatsMatch = Regex.Match(block, @"Seats:\s*(?<val>\d+)", RegexOptions.IgnoreCase);
                            if (seatsMatch.Success) seats = seatsMatch.Groups["val"].Value.Trim();
                            var milesMatch = Regex.Match(block, @"Miles:\s*(?<val>[0-9]+(?:\.[0-9]+)?)", RegexOptions.IgnoreCase);
                            if (milesMatch.Success) miles = milesMatch.Groups["val"].Value.Trim();
                            var notesMatch = Regex.Match(block, @"Notes:\s*(?<val>[^\r\n]*)", RegexOptions.IgnoreCase);
                            if (notesMatch.Success) notes = notesMatch.Groups["val"].Value.Trim();
                        }
                        catch
                        {
                            // ignore extraction failures
                        }

                        var appointment = new Appointment
                        {
                            PatientId = patient.Id,
                            HospitalId = hospital.Id,
                            PickupTime = pickup,
                            AppointmentTime = drop,
                            PickupAddress = pickupAddress,
                            Notes = notes
                        };

                        _context.Appointments.Add(appointment);
                        // persist to get appointment.Id
                        await _context.SaveChangesAsync();

                        // ✅ DRIVER ASSIGN (IMPROVED)
                        var driver = drivers.FirstOrDefault(d =>
                            d.ShiftStartTime <= pickup.TimeOfDay &&
                            d.ShiftEndTime >= pickup.TimeOfDay
                        ) ?? drivers.FirstOrDefault();

                        if (driver != null)
                        {
                            var route = routes.FirstOrDefault(r =>
                                r.DriverId == driver.Id &&
                                r.RouteDate.Date == pickup.Date);

                            if (route == null)
                            {
                                route = new Route
                                {
                                    DriverId = driver.Id,
                                    RouteDate = pickup.Date
                                };

                                _context.Routes.Add(route);
                                routes.Add(route);
                            }

                            _context.RouteAppointments.Add(new RouteAppointment
                            {
                                Route = route,
                                Appointment = appointment,
                                SequenceOrder = 1,
                                IsActive = true
                            });
                        }

                        importedCount++;
                    }
                    catch
                    {
                        continue;
                    }
                }

                // ✅ SAVE ONCE (BIG PERFORMANCE BOOST)
                await _context.SaveChangesAsync();

                TempData["ImportMessage"] = $"Imported {importedCount} records.";
            }
            finally
            {
                System.IO.File.Delete(tempPath);
            }

            return RedirectToAction(nameof(Index));
        }






