using Microsoft.AspNetCore.Authorization;
using Microsoft.AspNetCore.Http;
using Microsoft.AspNetCore.Mvc;
using System.Collections;
using System.Linq;
using System.Reflection;
using System.Text;
using System.Text.RegularExpressions;
using System.Net.Http;
using System.Text.Json;
using TransportProject.DatabaseContext;
using TransportProject.Models;
using TransportProject.Repositories.Interface;
using Microsoft.Extensions.Configuration;
using UglyToad.PdfPig;

namespace TransportProject.Controllers
{
    [Authorize(Roles = "Admin,Dispatcher")]
    public class RouteAppointmentController : Controller
    {
        private readonly IRouteAppointmentRepository _repository;
        private readonly ApplicationDbContext _context;
        private readonly IConfiguration _configuration;

        public RouteAppointmentController(IRouteAppointmentRepository repository, ApplicationDbContext context, IConfiguration configuration)
        {
            _repository = repository;
            _context = context;
            _configuration = configuration;
        }

        public async Task<IActionResult> Index()
        {
            var items = await _repository.GetAllAsync();
            return View(items);
        }

        public async Task<IActionResult> Edit(int id)
        {
            var item = await _repository.GetByIdAsync(id);
            return View(item);
        }

        [HttpPost]
        public async Task<IActionResult> Edit(RouteAppointment model)
        {
            await _repository.UpdateAsync(model);
            return RedirectToAction(nameof(Index));
        }

        public async Task<IActionResult> Delete(int id)
        {
            await _repository.DeleteAsync(id);
            return RedirectToAction(nameof(Index));
        }

        // GET: show upload form
        public IActionResult ImportFile()
        {
            return View();
        }

        // POST: upload file (pdf or plain text). Shortest-path: if you need reliable PDF parsing, add the "UglyToad.PdfPig" NuGet package.
        // This implementation supports plain text files. If "UglyToad.PdfPig" is present in the app's bin it will be used via reflection to extract text from PDF.
        [HttpPost]
        [ValidateAntiForgeryToken]
        public async Task<IActionResult> ImportFile(IFormFile file, bool clearExisting = false)
        {
            if (file == null || file.Length == 0)
            {
                ModelState.AddModelError("file", "Please provide a file.");
                return View();
            }

            var tempPath = Path.Combine(Path.GetTempPath(), Guid.NewGuid() + Path.GetExtension(file.FileName));

            await using (var fs = System.IO.File.Create(tempPath))
                await file.CopyToAsync(fs);

            string rawText = "";

            try
            {
                var ext = Path.GetExtension(file.FileName).ToLower();

                if (ext == ".pdf")
                {
                        try
                        {
                            var asm = Assembly.Load("UglyToad.PdfPig");
                            if (asm == null)
                            {
                                ModelState.AddModelError("file", "UglyToad.PdfPig not available at runtime. Install the package or upload a .txt file.");
                                return View();
                            }

                            var pdfDocType = asm.GetType("UglyToad.PdfPig.PdfDocument");
                            if (pdfDocType == null)
                            {
                                ModelState.AddModelError("file", "Unexpected PdfPig runtime: PdfDocument type not found. Install the package or upload a .txt file.");
                                return View();
                            }

                            var openMethod = pdfDocType.GetMethod("Open", new[] { typeof(string) });
                            if (openMethod == null)
                            {
                                ModelState.AddModelError("file", "Unexpected PdfPig runtime: Open method not found. Install the package or upload a .txt file.");
                                return View();
                            }

                            var pdfObj = openMethod.Invoke(null, new object[] { tempPath });
                            if (pdfObj == null)
                            {
                                ModelState.AddModelError("file", "Failed to open PDF document. Ensure the PDF is valid or upload a .txt file.");
                                return View();
                            }

                            var getPages = pdfObj.GetType().GetMethod("GetPages");
                            var pages = getPages?.Invoke(pdfObj, null) as IEnumerable;

                            var sb = new StringBuilder();

                            if (pages != null)
                            {
                                foreach (var p in pages)
                                {
                                    var prop = p.GetType().GetProperty("Text");
                                    var text = prop?.GetValue(p)?.ToString();
                                    if (!string.IsNullOrWhiteSpace(text))
                                        sb.AppendLine(text);
                                }
                            }

                            rawText = sb.ToString();

                            if (pdfObj is System.IDisposable disp) disp.Dispose();
                        }
                        catch
                        {
                            ModelState.AddModelError("file", "Install UglyToad.PdfPig OR upload .txt file.");
                            return View();
                        }
                }
                else
                {
                    rawText = await System.IO.File.ReadAllTextAsync(tempPath);
                }

                rawText = rawText.Replace("\r\n", "\n").Replace("\r", "\n");

                // ✅ FIXED BLOCK SPLIT
                var blocks = Regex.Split(rawText, @"(?=\d{2}-\d{3,})");

                // optionally clear existing appointments/routeappointments before import
                if (clearExisting)
                {
                    _context.RouteAppointments.RemoveRange(_context.RouteAppointments);
                    _context.Appointments.RemoveRange(_context.Appointments);
                    await _context.SaveChangesAsync();
                }

                // 🔥 CACHE DATA (IMPORTANT)
                var hospitals = _context.Hospitals.ToList();
                var patients = _context.Patients.ToList();
                var drivers = _context.Drivers.Where(d => d.IsActive && d.IsAvailable).ToList();
                var routes = _context.Routes.ToList();

                int importedCount = 0;

                foreach (var raw in blocks)
                {
                    var block = raw.Trim();
                    if (string.IsNullOrWhiteSpace(block)) continue;

                    try
                    {
                        var lines = block.Split('\n').Select(x => x.Trim()).ToList();

                        string rideNumber = lines.FirstOrDefault() ?? "";

                        // ✅ NAME FIX
                        var nameMatch = Regex.Match(block, @"([A-Z]+,\s*[A-Z]+)");
                        string firstName = "", lastName = "";

                        if (nameMatch.Success)
                        {
                            var parts = nameMatch.Value.Split(',');
                            lastName = parts[0].Trim();
                            firstName = parts[1].Trim();
                        }

                        // ✅ TIME FIX
                        var times = Regex.Matches(block, @"\b\d{1,2}:\d{2}\b")
                                         .Cast<Match>()
                                         .Select(m => m.Value)
                                         .ToList();

                        DateTime pickup = DateTime.Today;
                        DateTime drop = DateTime.Today;

                        if (times.Count > 0) pickup += TimeSpan.Parse(times[0]);
                        if (times.Count > 1) drop += TimeSpan.Parse(times[1]);

                        // ✅ SIMPLE ADDRESS
                        var pickupAddress = lines.FirstOrDefault(l => l.Contains("PU")) ?? "";
                        var dropLine = lines.FirstOrDefault(l => l.StartsWith("DO")) ?? "";

                        var hospitalName = dropLine.Replace("DO", "").Trim();

                        // ✅ FIND OR CREATE HOSPITAL
                        var hospital = hospitals.FirstOrDefault(h => h.Name == hospitalName);
                        if (hospital == null)
                        {
                            hospital = new Hospital { Name = hospitalName };
                            _context.Hospitals.Add(hospital);
                            // persist now so we have an Id for FK usage
                            await _context.SaveChangesAsync();
                            hospitals.Add(hospital);
                        }

                        // ✅ FIND OR CREATE PATIENT
                        var patient = patients.FirstOrDefault(p => p.FirstName == firstName && p.LastName == lastName);

                        if (patient == null)
                        {
                            patient = new Patient
                            {
                                FirstName = firstName,
                                LastName = lastName,
                                Address = pickupAddress,
                                HospitalId = hospital.Id
                            };

                            _context.Patients.Add(patient);
                            // persist to get patient.Id
                            await _context.SaveChangesAsync();
                            patients.Add(patient);
                        }

                        // Extract LOS/CPay/PCA/AESC/CESC/Seats/Miles/Notes from block
                        string los = null;
                        string cpay = null;
                        string pca = null;
                        string aesc = null;
                        string cesc = null;
                        string seats = null;
                        string miles = null;
                        string notes = null;

                        try
                        {
                            var losMatch = Regex.Match(block, @"LOS:\s*(?<val>[^\r\n]*)", RegexOptions.IgnoreCase);
                            if (losMatch.Success) los = Regex.Replace(losMatch.Groups["val"].Value, @"\s+", " ").Trim();
                            var cpayMatch = Regex.Match(block, @"CPay:\s*\$?(?<val>[0-9,\.]+)", RegexOptions.IgnoreCase);
                            if (cpayMatch.Success) cpay = cpayMatch.Groups["val"].Value.Trim();
                            var pcaMatch = Regex.Match(block, @"PCA:\s*(?<val>\d+)", RegexOptions.IgnoreCase);
                            if (pcaMatch.Success) pca = pcaMatch.Groups["val"].Value.Trim();
                            var aescMatch = Regex.Match(block, @"AESC:\s*(?<val>\d+)", RegexOptions.IgnoreCase);
                            if (aescMatch.Success) aesc = aescMatch.Groups["val"].Value.Trim();
                            var cescMatch = Regex.Match(block, @"CESC:\s*(?<val>\d+)", RegexOptions.IgnoreCase);
                            if (cescMatch.Success) cesc = cescMatch.Groups["val"].Value.Trim();
                            var seatsMatch = Regex.Match(block, @"Seats:\s*(?<val>\d+)", RegexOptions.IgnoreCase);
                            if (seatsMatch.Success) seats = seatsMatch.Groups["val"].Value.Trim();
                            var milesMatch = Regex.Match(block, @"Miles:\s*(?<val>[0-9]+(?:\.[0-9]+)?)", RegexOptions.IgnoreCase);
                            if (milesMatch.Success) miles = milesMatch.Groups["val"].Value.Trim();
                            var notesMatch = Regex.Match(block, @"Notes:\s*(?<val>[^\r\n]*)", RegexOptions.IgnoreCase);
                            if (notesMatch.Success) notes = notesMatch.Groups["val"].Value.Trim();
                        }
                        catch
                        {
                            // ignore extraction failures
                        }

                        var appointment = new Appointment
                        {
                            PatientId = patient.Id,
                            HospitalId = hospital.Id,
                            PickupTime = pickup,
                            AppointmentTime = drop,
                            PickupAddress = pickupAddress,
                            Notes = notes
                        };

                        // set status if marked canceled in the block
                        if (Regex.IsMatch(block, "CANCELED", RegexOptions.IgnoreCase))
                            appointment.Status = "Canceled";

                        // try optional geocoding using Google Maps API if api key present
                        try
                        {
                            var gKey = _configuration?["GoogleMaps:ApiKey"];
                            if (!string.IsNullOrWhiteSpace(gKey) && !string.IsNullOrWhiteSpace(pickupAddress))
                            {
                                using var http = new HttpClient();
                                var url = $"https://maps.googleapis.com/maps/api/geocode/json?address={Uri.EscapeDataString(pickupAddress)}&key={gKey}";
                                var resp = await http.GetStringAsync(url);
                                using var doc = JsonDocument.Parse(resp);
                                var results = doc.RootElement.GetProperty("results");
                                if (results.GetArrayLength() > 0)
                                {
                                    var location = results[0].GetProperty("geometry").GetProperty("location");
                                    appointment.PickupLatitude = location.GetProperty("lat").GetDouble();
                                    appointment.PickupLongitude = location.GetProperty("lng").GetDouble();
                                }
                            }
                        }
                        catch
                        {
                            // ignore geocode failures - import should continue
                        }

                        // attempt to geocode pickupAddress into Appointment.PickupLatitude/Longitude later
                        _context.Appointments.Add(appointment);
                        // persist to get appointment.Id
                        await _context.SaveChangesAsync();

                        // ✅ DRIVER ASSIGN (IMPROVED)
                        var driver = drivers.FirstOrDefault(d =>
                            d.ShiftStartTime <= pickup.TimeOfDay &&
                            d.ShiftEndTime >= pickup.TimeOfDay
                        ) ?? drivers.FirstOrDefault();

                        if (driver != null)
                        {
                            var route = routes.FirstOrDefault(r =>
                                r.DriverId == driver.Id &&
                                r.RouteDate.Date == pickup.Date);

                            if (route == null)
                            {
                                route = new TransportProject.Models.Route
                                {
                                    DriverId = driver.Id,
                                    RouteDate = pickup.Date
                                };

                                _context.Routes.Add(route);
                                routes.Add(route);
                            }

                            // compute sequence
                            var maxSeq = _context.RouteAppointments.Where(ra => ra.RouteId == route.Id && ra.IsActive).Select(ra => (int?)ra.SequenceOrder).Max() ?? 0;

                            // parse numeric fields
                            decimal? parsedCpay = null;
                            if (!string.IsNullOrWhiteSpace(cpay))
                            {
                                var cleaned = cpay.Replace("$", string.Empty).Trim();
                                if (decimal.TryParse(cleaned, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var d)) parsedCpay = d;
                            }

                            int? parsedPca = null;
                            if (int.TryParse(pca, out var ipca)) parsedPca = ipca;

                            int? parsedAesc = null;
                            if (int.TryParse(aesc, out var iaesc)) parsedAesc = iaesc;

                            int? parsedCesc = null;
                            if (int.TryParse(cesc, out var icesc)) parsedCesc = icesc;

                            int? parsedSeats = null;
                            if (int.TryParse(seats, out var iseats)) parsedSeats = iseats;

                            decimal? parsedMiles = null;
                            if (!string.IsNullOrWhiteSpace(miles))
                            {
                                var mclean = miles.Replace("miles", string.Empty, System.StringComparison.OrdinalIgnoreCase).Replace("\u00A0", " ").Trim();
                                if (decimal.TryParse(mclean, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var dm)) parsedMiles = dm;
                            }

                            var ra = new RouteAppointment
                            {
                                RouteId = route.Id,
                                AppointmentId = appointment.Id,
                                SequenceOrder = maxSeq + 1,
                                LOS = string.IsNullOrWhiteSpace(los) ? null : los,
                                CPay = parsedCpay,
                                PCA = parsedPca,
                                AESC = parsedAesc,
                                CESC = parsedCesc,
                                Seats = parsedSeats,
                                Miles = parsedMiles,
                                Notes = string.IsNullOrWhiteSpace(notes) ? null : notes,
                                IsActive = true
                            };

                            _context.RouteAppointments.Add(ra);
                        }

                        importedCount++;
                    }
                    catch
                    {
                        continue;
                    }
                }

                // ✅ SAVE ONCE (BIG PERFORMANCE BOOST)
                await _context.SaveChangesAsync();

                TempData["ImportMessage"] = $"Imported {importedCount} records.";
            }
            finally
            {
                System.IO.File.Delete(tempPath);
            }

            return RedirectToAction(nameof(Index));
        }





    }
}
