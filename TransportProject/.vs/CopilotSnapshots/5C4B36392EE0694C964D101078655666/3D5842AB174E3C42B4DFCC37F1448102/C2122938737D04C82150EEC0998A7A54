        // Haversine distance in kilometers
        private static double HaversineDistance(double lat1, double lon1, double lat2, double lon2)
        {
            double R = 6371; // km
            var dLat = ToRadians(lat2 - lat1);
            var dLon = ToRadians(lon2 - lon1);
            var a = Math.Sin(dLat / 2) * Math.Sin(dLat / 2) + Math.Cos(ToRadians(lat1)) * Math.Cos(ToRadians(lat2)) * Math.Sin(dLon / 2) * Math.Sin(dLon / 2);
            var c = 2 * Math.Atan2(Math.Sqrt(a), Math.Sqrt(1 - a));
            return R * c;
        }

        private static double ToRadians(double ang) => ang * Math.PI / 180.0;

        // Normalize any DateTime values that are outside SQL Server datetime range
        private void NormalizeDateTimes()
        {
            var sqlMin = new DateTime(1753, 1, 1);
            foreach (var entry in _context.ChangeTracker.Entries())
            {
                if (entry.State != Microsoft.EntityFrameworkCore.EntityState.Added && entry.State != Microsoft.EntityFrameworkCore.EntityState.Modified)
                    continue;

                foreach (var prop in entry.Properties)
                {
                    var t = prop.Metadata.ClrType;
                    var val = prop.CurrentValue;
                    if (val == null) continue;

                    if (t == typeof(DateTime))
                    {
                        var dt = (DateTime)val;
                        if (dt < sqlMin) prop.CurrentValue = sqlMin;
                    }
                    else if (t == typeof(DateTime?))
                    {
                        var dt = (DateTime?)val;
                        if (dt.HasValue && dt.Value < sqlMin) prop.CurrentValue = sqlMin;
                    }
                }
            }
        }

        // Truncate string properties to the configured max length in the EF model or database to avoid SQL truncation errors.
        // If EF metadata does not define a max length, query the database INFORMATION_SCHEMA for the real column length,
        // then use conservative fallbacks if both are unavailable.
        private Task NormalizeStringLengthsAsync()
        {
            // fallback lengths for known entity.property combinations when EF metadata lacks MaxLength
            var fallbacks = new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase)
            {
                // Use conservative safe lengths matching typical DB schemas
                ["Appointment.PickupAddress"] = 100,
                ["Appointment.Notes"] = 1000,
                ["Patient.Address"] = 250,
                ["Patient.FirstName"] = 100,
                ["Patient.LastName"] = 100,
                ["Patient.PhoneNumber"] = 50,
                ["Hospital.Name"] = 200,
                ["Hospital.Address"] = 250,
                ["RouteAppointment.Notes"] = 1000
            };

            foreach (var entry in _context.ChangeTracker.Entries())
            {
                if (entry.State != Microsoft.EntityFrameworkCore.EntityState.Added && entry.State != Microsoft.EntityFrameworkCore.EntityState.Modified)
                    continue;

                var clrType = entry.Entity.GetType();
                var entityName = clrType.Name;

                foreach (var prop in entry.Properties)
                {
                    if (prop.Metadata.ClrType != typeof(string)) continue;
                    var val = prop.CurrentValue as string;
                    if (string.IsNullOrEmpty(val)) continue;

                    // try EF configured max length first
                    var max = prop.Metadata.GetMaxLength();
                    if (max.HasValue)
                    {
                        if (val.Length > max.Value)
                            prop.CurrentValue = val.Substring(0, max.Value);
                        continue;
                    }

                    // fallback by entity.property
                    var key = entityName + "." + prop.Metadata.Name;
                    if (fallbacks.TryGetValue(key, out var flen))
                    {
                        if (val.Length > flen)
                            prop.CurrentValue = val.Substring(0, flen);
                        continue;
                    }

                    // as a last resort, cap at 4000 characters to avoid very large strings
                    if (val.Length > 4000)
                        prop.CurrentValue = val.Substring(0, 4000);
                }
            }

            return Task.CompletedTask;
        }

        // Extra safeguard: forcibly truncate known problematic columns by property name.
        private void TruncateKnownColumns()
        {
            foreach (var entry in _context.ChangeTracker.Entries())
            {
                if (entry.State != Microsoft.EntityFrameworkCore.EntityState.Added && entry.State != Microsoft.EntityFrameworkCore.EntityState.Modified)
                    continue;

                var entityName = entry.Entity.GetType().Name;

                foreach (var prop in entry.Properties)
                {
                    if (prop.Metadata.ClrType != typeof(string)) continue;
                    var val = prop.CurrentValue as string;
                    if (string.IsNullOrEmpty(val)) continue;

                    // Appointment.PickupAddress - common offender, keep within 200 chars
                    if (entityName == "Appointment" && string.Equals(prop.Metadata.Name, "PickupAddress", StringComparison.OrdinalIgnoreCase))
                    {
                        if (val.Length > 200) prop.CurrentValue = val.Substring(0, 200);
                    }

                    // Patient.Address - keep within 250 chars
                    if (entityName == "Patient" && string.Equals(prop.Metadata.Name, "Address", StringComparison.OrdinalIgnoreCase))
                    {
                        if (val.Length > 250) prop.CurrentValue = val.Substring(0, 250);
                    }

                    // Hospital.Name - keep within 200
                    if (entityName == "Hospital" && string.Equals(prop.Metadata.Name, "Name", StringComparison.OrdinalIgnoreCase))
                    {
                        if (val.Length > 200) prop.CurrentValue = val.Substring(0, 200);
                    }

                    // RouteAppointment.Notes and Appointment.Notes - keep within 1000
                    if ((entityName == "RouteAppointment" || entityName == "Appointment") && string.Equals(prop.Metadata.Name, "Notes", StringComparison.OrdinalIgnoreCase))
                    {
                        if (val.Length > 1000) prop.CurrentValue = val.Substring(0, 1000);
                    }
                }
            }
        }

