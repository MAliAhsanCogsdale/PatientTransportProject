        // POST: upload file (pdf or plain text). Shortest-path: if you need reliable PDF parsing, add the "UglyToad.PdfPig" NuGet package.
        // This implementation supports plain text files. If "UglyToad.PdfPig" is present in the app's bin it will be used via reflection to extract text from PDF.

        [HttpPost]
        [ValidateAntiForgeryToken]
        public async Task<IActionResult> ImportFile(IFormFile file)
        {
            if (file == null || file.Length == 0)
            {
                ModelState.AddModelError("file", "Please provide a file.");
                return View();
            }

            var tempPath = Path.Combine(Path.GetTempPath(), Guid.NewGuid() + Path.GetExtension(file.FileName));

            await using (var fs = System.IO.File.Create(tempPath))
                await file.CopyToAsync(fs);

            try
            {
                string rawText = "";

                // =========================
                // READ FILE
                // =========================
                if (Path.GetExtension(file.FileName).ToLower() == ".pdf")
                {
                    using var pdf = UglyToad.PdfPig.PdfDocument.Open(tempPath);
                    var sb = new StringBuilder();
                    foreach (var page in pdf.GetPages())
                        sb.AppendLine(page.Text);

                    rawText = sb.ToString();
                }
                else
                {
                    rawText = await System.IO.File.ReadAllTextAsync(tempPath);
                }

                rawText = rawText.Replace("\r\n", "\n").Replace("\r", "\n");
                var blocks = Regex.Split(rawText, @"(?=\d{2}-\d{3,})");

                // =========================
                // MEMORY COLLECTIONS
                // =========================
                var hospitals = new List<Hospital>();
                var patients = new List<Patient>();
                var appointments = new List<Appointment>();

                var drivers = _context.Drivers
                    .Where(d => d.IsActive && d.IsAvailable)
                    .ToList();

                List<string> logs = new();

                // =========================
                // PHASE 1 → PARSE ONLY
                // =========================
                foreach (var raw in blocks)
                {
                    var block = raw.Trim();
                    if (string.IsNullOrWhiteSpace(block)) continue;

                    try
                    {
                        var lines = block.Split('\n').Select(x => x.Trim()).ToList();

                        // NAME
                        var nameMatch = Regex.Match(block, @"([A-Z]+,\s*[A-Z]+)");
                        if (!nameMatch.Success) continue;

                        var parts = nameMatch.Value.Split(',');
                        string firstName = parts[1].Trim();
                        string lastName = parts[0].Trim();

                        // TIME
                        var times = Regex.Matches(block, @"\b\d{1,2}:\d{2}(\s?[APMapm]{2})?\b")
                            .Cast<Match>().Select(m => m.Value).ToList();

                        if (times.Count < 2) continue;

                        if (!DateTime.TryParse(times[0], out var pickup) ||
                            !DateTime.TryParse(times[1], out var drop))
                            continue;

                        // ADDRESS
                        string pickupAddress = lines.FirstOrDefault(l => Regex.IsMatch(l, @"\d+\s+\w+"));
                        if (string.IsNullOrWhiteSpace(pickupAddress)) continue;

                        // HOSPITAL
                        var hospitalName = lines.FirstOrDefault(l => l.StartsWith("DO"))?.Replace("DO", "").Trim();
                        if (string.IsNullOrWhiteSpace(hospitalName)) continue;

                        // CREATE OBJECTS (NO DB YET)
                        var hospital = hospitals.FirstOrDefault(h => h.Name == hospitalName)
                                       ?? new Hospital { Name = hospitalName };

                        if (!hospitals.Any(h => h.Name == hospitalName))
                            hospitals.Add(hospital);

                        var patient = new Patient
                        {
                            FirstName = firstName,
                            LastName = lastName,
                            Address = pickupAddress,
                            VisitTime = drop
                        };

                        patients.Add(patient);

                        var appointment = new Appointment
                        {
                            PickupTime = pickup,
                            AppointmentTime = drop,
                            PickupAddress = pickupAddress,
                            Patient = patient,
                            Hospital = hospital
                        };

                        appointments.Add(appointment);
                    }
                    catch (Exception ex)
                    {
                        logs.Add(ex.Message);
                    }
                }

                // =========================
                // PHASE 2 → SAVE DATA
                // =========================
                await _context.Hospitals.AddRangeAsync(hospitals);
                await _context.Patients.AddRangeAsync(patients);
                await _context.Appointments.AddRangeAsync(appointments);

                await _context.SaveChangesAsync();

                // =========================
                // PHASE 3 → ROUTING
                // =========================
                var routes = new List<Route>();
                var routeAppointments = new List<RouteAppointment>();

                foreach (var appt in appointments)
                {
                    var driver = drivers.FirstOrDefault();
                    if (driver == null) continue;

                    var route = routes.FirstOrDefault(r => r.DriverId == driver.Id && r.RouteDate == appt.PickupTime.Date);

                    if (route == null)
                    {
                        route = new Route
                        {
                            DriverId = driver.Id,
                            RouteDate = appt.PickupTime.Date
                        };
                        routes.Add(route);
                    }

                    int seq = routeAppointments
                        .Where(x => x.RouteId == route.Id)
                        .Select(x => x.SequenceOrder)
                        .DefaultIfEmpty(0)
                        .Max() + 1;

                    routeAppointments.Add(new RouteAppointment
                    {
                        Route = route,
                        Appointment = appt,
                        SequenceOrder = seq
                    });
                }

                await _context.Routes.AddRangeAsync(routes);
                await _context.RouteAppointments.AddRangeAsync(routeAppointments);

                await _context.SaveChangesAsync();

                TempData["ImportMessage"] = $"✅ Imported {appointments.Count}";
            }
            finally
            {
                if (System.IO.File.Exists(tempPath))
                    System.IO.File.Delete(tempPath);
            }

            return RedirectToAction(nameof(Index));
        }

    
