        // POST: perform one-off data cleanup/trimming on patient/appointment/routeappointment text fields
        [HttpPost]
        [ValidateAntiForgeryToken]
        public async Task<IActionResult> CleanupData()
        {
            // load into memory to avoid EF change-tracking enumeration issues
            var patients = _context.Patients.ToList();
            foreach (var p in patients)
            {
                p.FirstName = (p.FirstName ?? string.Empty).Trim();
                p.LastName = (p.LastName ?? string.Empty).Trim();
                p.Address = (p.Address ?? string.Empty).Trim();
                if (p.Address?.Length > 500) p.Address = p.Address.Substring(0, 500);
            }

            var appointments = _context.Appointments.ToList();
            foreach (var a in appointments)
            {
                a.PickupAddress = (a.PickupAddress ?? string.Empty).Trim();
                if (a.PickupAddress?.Length > 500) a.PickupAddress = a.PickupAddress.Substring(0, 500);
                a.Notes = (a.Notes ?? string.Empty).Trim();
                if (a.Notes?.Length > 2000) a.Notes = a.Notes.Substring(0, 2000);
            }

            var ras = _context.RouteAppointments.ToList();
            foreach (var ra in ras)
            {
                ra.LOS = (ra.LOS ?? string.Empty).Trim();
                if (ra.LOS?.Length > 50) ra.LOS = ra.LOS.Substring(0, 50);
                ra.Notes = (ra.Notes ?? string.Empty).Trim();
                if (ra.Notes?.Length > 2000) ra.Notes = ra.Notes.Substring(0, 2000);
            }

            await _context.SaveChangesAsync();
            TempData["ImportMessage"] = "Data cleanup completed.";
            return RedirectToAction(nameof(Index));
        }

