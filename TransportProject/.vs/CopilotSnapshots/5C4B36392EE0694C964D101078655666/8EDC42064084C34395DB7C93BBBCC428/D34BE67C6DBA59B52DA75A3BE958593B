        // POST: upload file (pdf or plain text). Shortest-path: if you need reliable PDF parsing, add the "UglyToad.PdfPig" NuGet package.
        // This implementation supports plain text files. If "UglyToad.PdfPig" is present in the app's bin it will be used via reflection to extract text from PDF.

        [HttpPost]
        [ValidateAntiForgeryToken]
        public async Task<IActionResult> ImportFile(IFormFile file, bool clearExisting = false)
        {
            if (file == null || file.Length == 0)
                throw new ArgumentException("File is empty");

            // ❌ DISABLE HARD DELETE (IMPORTANT)
            // We will NOT delete all data anymore
            if (clearExisting)
            {
                Console.WriteLine("⚠️ ClearExisting ignored for safety");
            }

            var appointments = new List<Appointment>();
            var routeAppointments = new List<RouteAppointment>();

            using (var stream = new MemoryStream())
            {
                await file.CopyToAsync(stream);
                stream.Position = 0;

                using (var document = UglyToad.PdfPig.PdfDocument.Open(stream))
                {
                    foreach (var page in document.GetPages())
                    {
                        var text = page.Text;

                        var lines = text
                            .Split('\n')
                            .Select(x => x.Trim())
                            .Where(x => !string.IsNullOrWhiteSpace(x))
                            .ToList();

                        for (int i = 0; i < lines.Count; i++)
                        {
                            // Example condition (adjust based on your PDF)
                            if (!lines[i].Contains("PU")) continue;

                            // 🔹 SAFE PICKUP ADDRESS EXTRACTION
                            string pickupAddress = "";

                            for (int j = i + 1; j < lines.Count; j++)
                            {
                                var line = lines[j];

                                if (string.IsNullOrWhiteSpace(line)) continue;

                                // ❌ Skip garbage text
                                if (line.Contains("Modivcare")) continue;
                                if (line.Contains("Transportation")) continue;
                                if (line.Contains("Trips")) continue;
                                if (Regex.IsMatch(line, @"^\d{1,2}/\d{1,2}")) continue;

                                // ✅ Looks like real address
                                if (Regex.IsMatch(line, @"\d+\s+\w+"))
                                {
                                    pickupAddress = line;
                                    break;
                                }
                            }

                            // 🔹 SAFE LENGTH (VERY IMPORTANT)
                            if (!string.IsNullOrEmpty(pickupAddress) && pickupAddress.Length > 100)
                                pickupAddress = pickupAddress.Substring(0, 100);

                            // 🔹 CREATE APPOINTMENT
                            var appointment = new Appointment
                            {
                                PickupAddress = pickupAddress,
                                AppointmentTime = DateTime.Now
                            };

                            appointments.Add(appointment);
                        }
                    }
                }
            }

            // ✅ SAVE ALL AT ONCE (BEST PRACTICE)
            await _context.Appointments.AddRangeAsync(appointments);
            await _context.SaveChangesAsync();

            return appointments.Count;
        }

      
    
